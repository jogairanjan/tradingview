NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tradingview_db
DB_USER=root
DB_PASSWORD=
# XAMPP/WAMP: leave empty for root with no password
# Or set your MySQL root password

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=TradingView Signals <noreply@example.com>

# Python bridge (use 127.0.0.1 on Windows — avoids IPv6 ::1 connection refused)
PYTHON_BRIDGE_URL=http://127.0.0.1:8000
PYTHON_SIGNAL_ENDPOINT=/api/generate-signal

# Payment (placeholder)
PAYMENT_WEBHOOK_SECRET=change_me_webhook_secret

# Admin seed (dev only)
ADMIN_EMAIL=admin@tradingview.local
ADMIN_PASSWORD=Admin@123456

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Development: set AUTH_RATE_LIMIT_DISABLED=true to avoid login lockouts
AUTH_RATE_LIMIT_DISABLED=true
AUTH_RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
