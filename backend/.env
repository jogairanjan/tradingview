NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MySQL (XAMPP default: root with no password)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tradingview_db
DB_USER=root
DB_PASSWORD=

# JWT
JWT_ACCESS_SECRET=dev_access_secret_change_in_production_min32
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_min32
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Python bridge (optional — signals still work with mock data if offline)
PYTHON_BRIDGE_URL=http://127.0.0.1:8000
PYTHON_SIGNAL_ENDPOINT=/api/generate-signal

# Admin seed
ADMIN_EMAIL=admin@tradingview.local
ADMIN_PASSWORD=Admin@123456

# Rate limits (development — auth limiter disabled to avoid lockout while testing)
AUTH_RATE_LIMIT_DISABLED=true
AUTH_RATE_LIMIT_MAX=500
RATE_LIMIT_MAX=1000
