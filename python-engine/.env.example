# Flask server
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=false

# Exchange (ccxt) - optional; mock data used if fetch fails
EXCHANGE_ID=binance
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_SANDBOX=false

# Signal engine defaults
DEFAULT_TIMEFRAME=1h
DEFAULT_MARKET_TYPE=spot
OHLCV_LIMIT=200
MIN_CONFIDENCE=0.35

# Risk / targets (ATR multipliers)
ATR_STOP_MULTIPLIER=1.5
ATR_TARGET_1=1.0
ATR_TARGET_2=2.0
ATR_TARGET_3=3.0
